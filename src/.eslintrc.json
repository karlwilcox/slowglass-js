{
  "env": {
    "es2022": true,
    "browser": true,
    "node": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "camelcase": ["error", { "properties": "always" }],
    "new-cap": ["error", { "newIsCap": true, "capIsNew": false }],
    "no-underscore-dangle": ["warn"],
    "id-match": [
      "error",
      "^[a-z][a-zA-Z0-9]*$",
      {
        "properties": true,
        "onlyDeclarations": false
      }
    ]
  }
}